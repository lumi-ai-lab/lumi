<<< [claude] {"jsonrpc":"2.0","method":"session/update","params":{"sessionId":"4bcb66c1-3766-4c01-a666-9568ed96e7ba","update":{"sessionUpdate":"available_commands_update","availableCommands":[{"name":"update-config","description":"Use this skill to configure the Claude Code harness via settings.json. Automated behaviors (\"from now on when X\", \"each time X\", \"whenever X\", \"before/after X\") require hooks configured in settings.json - the harness executes these, not Claude, so memory/preferences cannot fulfill them. Also use for: permissions (\"allow X\", \"add permission\", \"move permission to\"), env vars (\"set X=Y\"), hook troubleshooting, or any changes to settings.json/settings.local.json files. Examples: \"allow npm commands\", \"add bq permission to global settings\", \"move permission to user settings\", \"set DEBUG=true\", \"when claude stops show X\". For simple settings like theme/model, use Config tool.","input":null},{"name":"debug","description":"Enable debug logging for this session and help diagnose issues","input":{"hint":"[issue description]"}},{"name":"simplify","description":"Review changed code for reuse, quality, and efficiency, then fix any issues found.","input":null},{"name":"batch","description":"Research and plan a large-scale change, then execute it in parallel across 5–30 isolated worktree agents that each open a PR.","input":{"hint":"<instruction>"}},{"name":"fewer-permission-prompts","description":"Scan your transcripts for common read-only Bash and MCP tool calls, then add a prioritized allowlist to project .claude/settings.json to reduce permission prompts.","input":null},{"name":"loop","description":"Run a prompt or slash command on a recurring interval (e.g. /loop 5m /foo). Omit the interval to let the model self-pace.","input":{"hint":"[interval] <prompt>"}},{"name":"schedule","description":"Create, update, list, or run scheduled remote agents (triggers) that execute on a cron schedule.","input":null},{"name":"claude-api","