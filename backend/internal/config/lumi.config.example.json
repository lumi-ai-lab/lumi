{
  "publicServerURL": "",
  "agents": [
    {
      "args": [
        "-y",
        "@agentclientprotocol/claude-agent-acp@0.30.0"
      ],
      "command": "npx",
      "id": "claude",
      "name": "Claude Code",
      "sessionMode": "default"
    },
    {
      "args": [
        "-y",
        "@zed-industries/codex-acp"
      ],
      "command": "npx",
      "id": "codex",
      "name": "Codex CLI",
      "sessionMode": "default"
    },
    {
      "args": [
        "-y",
        "@qwen-code/qwen-code",
        "--acp"
      ],
      "command": "npx",
      "id": "qwen",
      "name": "Qwen Code",
      "sessionMode": "default"
    }
  ],
  "defaultAgent": "claude",
  "routing": {
    "keywords": {
      "@claude": "claude",
      "@codex": "codex",
      "@qwen": "qwen"
    },
    "meta": true
  }  
}
